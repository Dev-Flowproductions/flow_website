# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=info@flowproductions.pt
CONTACT_INBOX_EMAIL=info@flowproductions.pt

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-1051059133566371

# Witflow CMS → blog sync (POST /api/webhooks/blog or /api/cms-webhook)
# REQUIRED: header x-webhook-secret must match CMS_WEBHOOK_SECRET (requests fail closed if unset)
# Events: post.published, post.updated (and legacy cms.post.*)
CMS_WEBHOOK_SECRET=your-cms-webhook-secret

# Auth (optional additional secrets)
JWT_SECRET=your-jwt-secret-key

# OpenAI — Martech / service diagnostic tools (model: gpt-5.5)
# Public tool routes require same-site Origin/Referer + rate limits
OPENAI_API_KEY=your-openai-api-key
# Legacy (optional fallback until Vercel env is migrated)
# GEMINI_API_KEY=

# Optional: one-off scripts against an old Supabase project
# LEGACY_SUPABASE_URL=https://your-old-project.supabase.co
# LEGACY_SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key
